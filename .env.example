# Core server
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
ALLOW_ORIGINS=*
REDIRECT_ALLOWLIST=http://localhost:61696/callback,http://localhost:3000/callback,urn:ietf:wg:oauth:2.0:oob
FRONTEND_URL=https://example.com

# Signing / OAuth
# Must be at least 32 bytes.
JWT_SIGNING_KEY=replace-with-strong-random-secret-at-least-32-bytes
JWT_AUDIENCE=commands-gateway
ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_CODE_TTL_SECONDS=300
REFRESH_TOKEN_TTL_SECONDS=2592000

# OAuth client metadata (returned by /register and used as default client_id)
OAUTH_DEFAULT_CLIENT_ID=oss-gateway-public-client
OAUTH_CLIENT_NAME=OSS Gateway
# Defaults to REDIRECT_ALLOWLIST when empty
OAUTH_REDIRECT_URIS=

# State backend
# memory is the only supported backend in this OSS baseline.
STATE_BACKEND=memory

# Auth mode: demo | firebase | oidc
AUTH_MODE=demo
DEMO_AUTH_DISABLED=false
DEMO_TOKEN_TTL_SECONDS=3600

# Public ingress rate limits (fixed window)
INGRESS_RATE_WINDOW_SECONDS=60
INGRESS_GLOBAL_LIMIT_PER_WINDOW=3000
INGRESS_IP_LIMIT_PER_WINDOW=600
INGRESS_ROUTE_LIMIT_PER_WINDOW=300

# Firebase mode
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# OIDC mode
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
